# --- Auth & OpenAI ---
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Production (Vercel): your deployment URL, no trailing slash
# AUTH_URL="https://your-app.vercel.app"
OPENAI_API_KEY="sk-..."

# --- Supabase Postgres (recommended) ---
# In Supabase: Project Settings → Database → Connection string
#
# Option A — Single "Direct connection" (simplest for local dev):
#   Paste the URI (port 5432) into BOTH variables below (same value).
#
# Option B — Pooled app + direct migrations (better for serverless / Vercel):
#   DATABASE_URL = "Transaction pooler" URI (port 6543) and add:
#     ?pgbouncer=true
#   DIRECT_URL   = "Direct connection" URI (port 5432), no pgbouncer param.
#
# Optional: fail fast instead of hanging (append to URL if not already present)
# &connect_timeout=15
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- Local Postgres (Docker) — set DATABASE_URL and DIRECT_URL to the SAME string ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postcraft"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postcraft"
