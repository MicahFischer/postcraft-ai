# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Vite
/dist

# legacy
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# vercel (may contain project/org identifiers)
.vercel

# cursor (local IDE settings — do not commit)
.cursor/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
